# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
bot.token=YOUR_BOT_TOKEN_HERE
bot.username=audio_grabber_r_bot

# Tool paths (default commands, will use PATH if available)
# These work if tools are in your system PATH
yt-dlp.path=yt-dlp
ffmpeg.path=ffmpeg
ffprobe.path=ffprobe

# Unix/Linux-specific absolute paths (uncomment and modify if needed)
# Use these if tools are not in PATH or you want specific versions
# yt-dlp.path.unix=/usr/local/bin/yt-dlp
# ffmpeg.path.unix=/usr/bin/ffmpeg
# ffprobe.path.unix=/usr/bin/ffprobe

# Windows-specific absolute paths (uncomment and modify if needed)
# Use these if tools are not in PATH or you want specific versions
# yt-dlp.path.win=C:/path/to/your/Tools/yt-dlp/yt-dlp.exe
# ffmpeg.path.win=C:/path/to/your/Tools/ffmpeg/bin/ffmpeg.exe
# ffprobe.path.win=C:/path/to/your/Tools/ffmpeg/bin/ffprobe.exe

# File size and duration limits
# Maximum file size in bytes (default: 50MB)
max.filesize=52428800

# Maximum video duration in minutes (default: 10 minutes)
max.duration=10.0

# Parallel downloads limit
max.parallel.downloads=3

# YouTube Cookies (optional, for bypassing bot-detection)
# Export cookies from your browser using a browser extension (e.g. "Get cookies.txt LOCALLY")
# and place the file on the server. Set the path here.
# Example: yt-dlp.cookies.path=/data/data/com.termux/files/home/cookies.txt
# Leave empty to disable (default)
yt-dlp.cookies.path=

# Duplicate detection (optional)
# Build this file with:
# java -cp youtube-mp3-downloader-1.0-SNAPSHOT-jar-with-dependencies.jar dev.telegrambots.youtubemp3downloader.MusicDuplicateIndexCli C:/Music C:/tmp/music-duplicate-index.tsv
# Copy the TSV to the server and set the server-side path here.
# Example: duplicate.index.path=/data/data/com.termux/files/home/termuxserver/src/music-duplicate-index.tsv
# Leave empty to disable duplicate detection.
duplicate.index.path=

# Configuration Instructions:
# 1. Copy this file to config.properties
# 2. Replace YOUR_BOT_TOKEN_HERE with your actual bot token from @BotFather
# 3. Update bot.username with your bot's username
# 4. Adjust paths if your tools are installed in custom locations:
#    - For Windows: uncomment and modify .win properties
#    - For Unix/Linux: uncomment and modify .unix properties
#    - Or set environment variables: YT_DLP_PATH, FFMPEG_PATH, FFPROBE_PATH
# 5. Modify limits based on your server capabilities and requirements
